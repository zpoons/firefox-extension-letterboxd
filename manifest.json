{
  "manifest_version": 2,
  "name": "goto letterboxd",
  "version": "1.3.1",
  "description": "Navigate between IMDb and Letterboxd pages. Includes auto-redirect and in-page buttons.",
  "icons": {
    "48": "favicon.ico",
    "96": "favicon.ico"
  },
  "browser_action": {
    "default_icon": "favicon.ico",
    "default_title": "Not a supported URL"
  },
  "content_scripts": [
    {
      "matches": [
        "https://letterboxd.com/*"
      ],
      "js": [
        "dist/content.js"
      ]
    },
    {
      "matches": [
        "https://www.imdb.com/*"
      ],
      "js": [
        "dist/utilities.js",
        "dist/imdb-content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    "favicon.ico"
  ],
  "background": {
    "scripts": [
      "dist/utilities.js",
      "dist/background.js"
    ]
  },
  "permissions": [
    "tabs",
    "storage",
    "menus"
  ]
}
